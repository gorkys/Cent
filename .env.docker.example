WEB_PORT=8080

# Shared PostgreSQL credentials for both the `postgres` and `api` services.
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DATABASE=cent
POSTGRES_USER=cent

POSTGRES_API_AUTH_SECRET=replace-with-a-long-random-secret
POSTGRES_API_CORS_ORIGIN=http://localhost:8080
POSTGRES_API_PUBLIC_BASE_URL=
POSTGRES_API_BODY_LIMIT_MB=15
POSTGRES_CONNECTION_LIMIT=10

VITE_GTAG_SCRIPT=
VITE_LOGIN_API_HOST=http://localhost
VITE_POSTGRES_API_HOST=/api/postgres
VITE_POSTGRES_PROXY_TARGET=http://127.0.0.1:8787
VITE_RATE_API_HOST=http://localhost
