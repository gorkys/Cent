# Minimal production config.
# In most cases you only need to change these three values.
WEB_PORT=3458
POSTGRES_PASSWORD=<postgres-password>
POSTGRES_API_AUTH_SECRET=<auth-secret>

# Optional advanced overrides:
# POSTGRES_USER=cent
# POSTGRES_DATABASE=cent
# CENT_WEB_IMAGE=gorkys/cent:latest
# CENT_API_IMAGE=gorkys/cent-api:latest
